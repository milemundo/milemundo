<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Iconic Las Vegas Hotels | Milemundo</title>
  <meta name="description" content="Discover the most iconic hotels in Las Vegas with Milemundo. Personalized tours, guided experiences, photos, comfort, scenic stops, and unforgettable adventures." />

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    html{
      scroll-behavior:smooth;
    }

    body{
      font-family:Arial, sans-serif;
      background:
        radial-gradient(circle at top, rgba(216,179,106,0.10), transparent 28%),
        linear-gradient(180deg,#364125 0%, #3f4a2c 35%, #342618 100%);
      color:#f5f1e8;
      line-height:1.6;
      overflow-x:hidden;
    }

    img{
      width:100%;
      display:block;
      border-radius:18px;
    }

    a{
      text-decoration:none;
      color:inherit;
    }

    .back-arrow{
      position:fixed;
      top:15px;
      left:15px;
      width:46px;
      height:46px;
      border-radius:50%;
      display:flex;
      align-items:center;
      justify-content:center;
      background:linear-gradient(135deg,#3a2718,#55643a);
      color:#fff;
      font-size:22px;
      z-index:1000;
      box-shadow:0 8px 20px rgba(0,0,0,0.28);
    }

    .lang-switch{
      position:fixed;
      top:15px;
      right:15px;
      display:flex;
      gap:8px;
      z-index:1000;
    }

    .lang-switch button{
      border:none;
      padding:10px 14px;
      border-radius:999px;
      cursor:pointer;
      font-weight:bold;
      background:rgba(255,255,255,0.12);
      color:#fff;
      backdrop-filter:blur(8px);
      transition:0.3s;
    }

    .lang-switch button.active{
      background:linear-gradient(135deg,#d8b36a,#8ea764);
      color:#2b1d12;
    }

    .hero{
      min-height:92vh;
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      padding:120px 20px 80px;
      background:
        linear-gradient(rgba(34,25,17,0.45), rgba(34,25,17,0.70)),
        url("las-vegas-hotels.jpg") center/cover no-repeat;
      position:relative;
    }

    .hero::after{
      content:"";
      position:absolute;
      inset:0;
      background:radial-gradient(circle at center, rgba(255,255,255,0.03), transparent 55%);
    }

    .hero-content{
      position:relative;
      z-index:2;
      max-width:900px;
    }

    .hero h1{
      font-size:clamp(2.3rem,5vw,4.5rem);
      color:#f7e7c1;
      margin-bottom:18px;
      text-shadow:0 4px 20px rgba(0,0,0,0.35);
    }

    .hero p{
      font-size:1.08rem;
      max-width:760px;
      margin:0 auto 28px;
      color:#f5f1e8;
    }

    .hero-buttons{
      display:flex;
      justify-content:center;
      gap:14px;
      flex-wrap:wrap;
    }

    .btn{
      display:inline-block;
      padding:14px 26px;
      border-radius:999px;
      font-weight:bold;
      transition:0.3s;
    }

    .btn-primary{
      background:linear-gradient(135deg,#d8b36a,#8ea764);
      color:#2b1d12;
      box-shadow:0 8px 24px rgba(0,0,0,0.24);
    }

    .btn-secondary{
      background:rgba(255,255,255,0.10);
      border:1px solid rgba(255,255,255,0.18);
      color:#fff;
      backdrop-filter:blur(6px);
    }

    .btn:hover{
      transform:translateY(-2px);
    }

    .section{
      width:min(1180px,92%);
      margin:auto;
      padding:85px 0;
    }

    .section-title{
      text-align:center;
      margin-bottom:18px;
      font-size:clamp(1.8rem,4vw,3rem);
      color:#f1d59a;
    }

    .section-subtitle{
      max-width:820px;
      margin:0 auto 46px;
      text-align:center;
      color:#efe5d6;
      font-size:1.05rem;
    }

    .intro-box{
      display:grid;
      grid-template-columns:1.15fr 1fr;
      gap:34px;
      align-items:center;
      background:rgba(255,255,255,0.05);
      border:1px solid rgba(255,255,255,0.08);
      border-radius:26px;
      padding:28px;
      box-shadow:0 12px 35px rgba(0,0,0,0.18);
    }

    .intro-text h2{
      font-size:2rem;
      color:#f1d59a;
      margin-bottom:16px;
    }

    .intro-text p{
      margin-bottom:14px;
      color:#f3eee4;
    }

    .highlights{
      margin-top:18px;
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:14px;
    }

    .highlight{
      background:rgba(255,255,255,0.05);
      border-radius:18px;
      padding:14px;
      border:1px solid rgba(255,255,255,0.06);
    }

    .highlight strong{
      display:block;
      color:#f1d59a;
      margin-bottom:6px;
    }

    .cards{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:24px;
      margin-top:20px;
    }

    .card{
      background:rgba(255,255,255,0.05);
      border:1px solid rgba(255,255,255,0.08);
      border-radius:24px;
      overflow:hidden;
      box-shadow:0 12px 32px rgba(0,0,0,0.18);
      transition:0.3s;
    }

    .card:hover{
      transform:translateY(-5px);
    }

    .card img{
      height:240px;
      object-fit:cover;
      border-radius:0;
    }

    .card-content{
      padding:22px;
    }

    .card h3{
      color:#f1d59a;
      margin-bottom:12px;
      font-size:1.35rem;
    }

    .card p{
      color:#f4efe5;
      margin-bottom:14px;
    }

    .tag{
      display:inline-block;
      padding:8px 14px;
      border-radius:999px;
      background:rgba(216,179,106,0.16);
      color:#f7dfaa;
      font-size:0.9rem;
      margin-top:6px;
    }

    .experience-grid{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:20px;
      margin-top:20px;
    }

    .experience-box{
      background:rgba(255,255,255,0.05);
      border:1px solid rgba(255,255,255,0.07);
      border-radius:22px;
      padding:22px;
      text-align:left;
    }

    .experience-box h4{
      color:#f1d59a;
      margin-bottom:10px;
      font-size:1.1rem;
    }

    .cta{
      text-align:center;
      background:
        linear-gradient(rgba(49,35,23,0.72), rgba(49,35,23,0.82)),
        url("vegas-night-tour.jpg") center/cover no-repeat;
      border-radius:28px;
      padding:70px 24px;
      box-shadow:0 15px 40px rgba(0,0,0,0.24);
    }

    .cta h2{
      font-size:clamp(2rem,4vw,3.2rem);
      color:#f7e1ab;
      margin-bottom:16px;
    }

    .cta p{
      max-width:760px;
      margin:0 auto 24px;
      color:#fff8ee;
      font-size:1.05rem;
    }

    footer{
      text-align:center;
      padding:30px 20px 40px;
      color:#e8dcc7;
      font-size:0.95rem;
    }

    .hidden{
      display:none !important;
    }

    @media (max-width: 980px){
      .intro-box,
      .cards,
      .experience-grid{
        grid-template-columns:1fr;
      }

      .highlights{
        grid-template-columns:1fr;
      }

      .card img{
        height:220px;
      }

      .hero{
        min-height:86vh;
        padding-top:130px;
      }
    }

    @media (max-width: 600px){
      .hero h1{
        font-size:2.2rem;
      }

